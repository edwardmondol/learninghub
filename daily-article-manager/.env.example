# ----------------------------------------------------------------------------
# Daily Article Manager — environment variables
# Copy this file to .env.local and fill in values. Never commit real secrets.
# ----------------------------------------------------------------------------

# --- Database (swappable) ---------------------------------------------------
# Default: SQLite (zero setup). The file is created on `npm run db:push`.
DATABASE_URL="file:./dev.db"
# To use Supabase/Postgres instead, change schema.prisma provider to
# "postgresql" and set, e.g.:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# --- News provider (Phase 1) ------------------------------------------------
# Primary news source. Get a free key at https://newsapi.org/
NEWSAPI_KEY=""
# Optional alternates (Phase 1 supports NewsAPI; alternates pluggable later)
# GNEWS_KEY=""
# NEWSDATA_KEY=""

# Comma-separated query terms used to pull trending news.
NEWS_QUERY="artificial intelligence,EdTech,startup funding Canada,leadership,Alberta innovation"

# --- Trends provider (Phase 2) ----------------------------------------------
# SERPAPI_KEY=""

# --- AI enrichment (Phase 2) ------------------------------------------------
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

# --- Cron protection --------------------------------------------------------
# Shared secret required to call /api/cron/refresh (Vercel Cron sends it).
CRON_SECRET="change-me"
